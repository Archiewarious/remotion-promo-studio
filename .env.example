# Скопируй этот файл в .env и заполни ключи.
# .env уже в .gitignore — он НЕ попадёт в публичный репозиторий.

# === Обязательные (для поиска b-roll) ===

# https://www.pexels.com/api/ — бесплатные фото и видео без лицензий
PEXELS_API_KEY=

# https://pixabay.com/api/docs/ — бесплатные фото, видео, музыка
PIXABAY_API_KEY=


# === Опциональные (для AI озвучки) ===

# https://platform.openai.com/api-keys — TTS, GPT
# OPENAI_API_KEY=

# https://elevenlabs.io — премиум TTS голоса
# ELEVENLABS_API_KEY=

# https://ai.google.dev — Gemini для генерации текста
# GEMINI_API_KEY=
